# TikTok Data Source Configuration
# Options: api, csv, mock
TIKTOK_DATA_SOURCE=mock

# TikTok API Configuration (required if TIKTOK_DATA_SOURCE=api)
TIKTOK_MS_TOKEN=your_ms_token_here

# CSV Data Source Configuration (required if TIKTOK_DATA_SOURCE=csv)
TIKTOK_USERS_FILE=data/tiktok_users.csv
TIKTOK_VIDEOS_FILE=data/tiktok_videos.csv

# Mock Data Source Configuration (used if TIKTOK_DATA_SOURCE=mock)
TIKTOK_MOCK_USER_COUNT=100
TIKTOK_MOCK_VIDEOS_PER_USER=10

# Video Storage Configuration
VIDEO_STORAGE_PATH=data/videos

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Email Configuration
EMAIL_SENDER=your_email@example.com
EMAIL_PASSWORD=your_email_password
EMAIL_SMTP_SERVER=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_RECIPIENT=recipient@example.com
